---
import type { Question } from '../data/questions';

interface Props {
  q: Question;
}
const { q } = Astro.props;

const starRows = q.story
  ? ([
      ['situation', 'Situation', q.story.situation],
      ['task', 'Task', q.story.task],
      ['action', 'Action', q.story.action],
      ['result', 'Result', q.story.result],
    ] as const).filter(([, , v]) => Boolean(v))
  : [];
---

<details class="qcard" id={q.id}>
  <summary>
    <span class="qlabel">Question:</span>
    <span class="qtext">{q.question}</span>
    <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>

  <div class="qbody">
    {q.whatTheyAsk && (
      <p class="probe"><strong>What they're really asking:</strong> {q.whatTheyAsk}</p>
    )}

    {q.answer && <p class="answer-text">{q.answer}</p>}

    {starRows.length > 0 && (
      <div class="star">
        {starRows.map(([k, label, val]) => (
          <div class="star-row" data-k={k}>
            <span class="star-key">{label}</span>
            <span class="star-val">{val}</span>
          </div>
        ))}
      </div>
    )}

    {q.tips && q.tips.length > 0 && (
      <>
        <p class="subhead">How to land it</p>
        <ul class="tips">
          {q.tips.map((t) => <li>{t}</li>)}
        </ul>
      </>
    )}

    {q.followUps && q.followUps.length > 0 && (
      <>
        <p class="subhead">Likely follow-ups</p>
        <div class="followups">
          {q.followUps.map((f) => <span class="fu">{f}</span>)}
        </div>
      </>
    )}
  </div>
</details>
