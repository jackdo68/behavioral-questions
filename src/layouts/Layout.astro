---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'star';
}

const { title, description = 'Behavioural interview prep — values, leadership and management questions with STAR answers.', active } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base.replace(/\/$/, '')}/${p}`.replace(/\/+/g, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />

    <!-- Social share preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(href('/og.svg'), Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(href('/og.svg'), Astro.site)} />

    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-brand" href={href('/')}>
          <img class="nav-logo" src={href('/favicon.svg')} alt="" width="26" height="26" /><span class="full">Behavioural Prep</span>
        </a>
        <div class="nav-links">
          <a href={href('/')} class={active === 'home' ? 'active' : ''}>Questions</a>
          <a href={href('/star')} class={active === 'star' ? 'active' : ''}>STAR Framework</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        Behavioural interview prep · built with Astro · {new Date().getFullYear()}
      </div>
    </footer>
  </body>
</html>
